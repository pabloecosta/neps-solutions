#include <iostream>

using namespace std;

int main(){

    int M[3][3];

    for(int i=0; i<3; i++){
        for(int x=0; x<3; x++){
            cin >> M[i][x];
        }
    }

    int maior = M[0][0];

    for(int i=0; i<3; i++){
        for(int x=0; x<3; x++){
            if(M[i][x]>maior){
                maior = M[i][x];
            }
        }
    }

    for(int i=0; i<3; i++){
        for(int x=0; x<3; x++){
            if(M[i][x]==maior){
                cout << -1;
            }
            else{
                cout << M[i][x];
            }
            if(x!=2){
                cout << " ";
            }
        }
        cout << "\n";
    }
}

